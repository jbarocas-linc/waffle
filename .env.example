# --- Client (Vite) ---
# Vite only exposes env vars prefixed with VITE_ to browser code — these two
# are read client-side to upload media directly to Supabase Storage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server (Vercel env vars — never exposed to the browser, no VITE_ prefix) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
PUBLIC_APP_URL=https://your-app.vercel.app
