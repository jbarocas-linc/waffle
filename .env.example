# --- Client (Vite) ---
# "local" = grids live in localStorage (no backend needed, great for development)
# "api"   = grids live in Supabase via the /api/* serverless functions
VITE_DATA_BACKEND=local

# Required when VITE_DATA_BACKEND=api (used client-side for media uploads only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server (Vercel env vars — never exposed to the browser) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
PUBLIC_APP_URL=https://your-app.vercel.app
